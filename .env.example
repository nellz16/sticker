# Wajib
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token
BOT_PHONE_NUMBER=628xxxxxxxxxx
OWNER_NUMBERS=628xxxxxxxxxx
OWNER_LIDS=
ALLOW_ALL_PRIVATE=false
ADMIN_KEY=change-this-to-a-long-random-secret

# Opsional
SESSION_ID=main
PORT=8000
LOG_LEVEL=info

# Sticker defaults
MAX_STICKER_BYTES=102400
DEFAULT_MODE=contain

# Memory/performance tuning
MAX_INPUT_BYTES=8388608
MAX_INPUT_PIXELS=12000000
WEBP_EFFORT=4
QUALITY_ATTEMPTS=6
MEMORY_RESTART_MB=460
LOG_MEMORY_AFTER_STICKER=false
